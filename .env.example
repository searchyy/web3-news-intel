APP_ENV=local
APP_NAME=web3-news-intel
APP_PORT=18080
FRONTEND_PORT=18081
DATABASE_URL=postgresql+psycopg://web3_news:web3_news@localhost:5432/web3_news_intel
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1
SOURCES_FILE=sources.yaml
ADMIN_TOKEN=
CORS_ALLOWED_ORIGINS=[]
HTTP_ALLOW_PRIVATE_NETWORKS=false
HTTP_ALLOW_LOCALHOST=false
HTTP_VALIDATE_DNS_REBINDING=true
HTTP_VALIDATE_SOURCE_DNS_ON_LOAD=false
HTTP_TRUST_ENV=false
HTTP_TIMEOUT_SECONDS=15
HTTP_MAX_RESPONSE_BYTES=2097152
HTTP_PER_HOST_RATE_LIMIT_SECONDS=1
HTTP_MAX_RETRIES=3
HTTP_MAX_REDIRECTS=5
HTTP_USER_AGENT=web3-news-intel/0.1 (+https://example.invalid/compliance)
AI_ENABLED=false
AI_AUTO_PROCESS_ENABLED=false
AI_PROVIDER=deepseek
AI_EXECUTION_MODE=async
AI_SYNC_TIMEOUT_SECONDS=60
AI_QUEUE_NAME=ai
AI_ALLOW_CUSTOM_API_BASE=false
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_REQUEST_TIMEOUT_SECONDS=90
DEEPSEEK_MAX_CONCURRENCY=2
DEEPSEEK_DAILY_TOKEN_BUDGET=0
CELERY_REDIS_VISIBILITY_TIMEOUT_SECONDS=3600
ENABLE_ACCEPTANCE_TASKS=false
ACCEPTANCE_MOCK_HTTP_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_SECRET=
FEISHU_ENABLED=false
FEISHU_SEND_ENABLED=false
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=
FEISHU_API_BASE=https://open.feishu.cn
FEISHU_TEST_CHAT_ID=
FEISHU_ALLOWED_CHAT_IDS=
FEISHU_DEFAULT_DELIVERY_MODE=immediate
FEISHU_MAX_MESSAGES_PER_GROUP_PER_HOUR=30
FIELD_ENCRYPTION_KEY=
PUBLIC_BASE_URL=
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=
ADMIN_SESSION_SECRET=
ADMIN_SESSION_TTL_SECONDS=28800
ADMIN_SECURE_COOKIE=false
